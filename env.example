# MediVerify Database Connection
# Supports PlanetScale, Railway, or Local MySQL
DATABASE_URL="mysql://user:password@host:3306/mediverify"

# Authentication Security
JWT_SECRET="secure_random_string_here"
JWT_REFRESH_SECRET="another_secure_random_string_for_refresh_tokens"
NEXTAUTH_SECRET="secure_random_string_for_oauth_session"

# Google OAuth
GOOGLE_CLIENT_ID="your-google-oauth-client-id.apps.googleusercontent.com"
VITE_GOOGLE_CLIENT_ID="your-google-oauth-client-id.apps.googleusercontent.com"

# Application Config
NODE_ENV="development"
VITE_API_URL="http://localhost:3000"

# SMTP (required for OTP email delivery)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="MediVerify <your-email@gmail.com>"

# Blockchain Gateway (Polygon Amoy testnet)
POLYGON_AMOY_RPC="https://rpc-amoy.polygon.technology"
BLOCKCHAIN_SIGNER_KEY="your-wallet-private-key-without-0x-prefix"
NEXT_PUBLIC_CONTRACT_ADDRESS="0xDeployedContractAddressHere"
