# MediVerify Database Connection
# Supports PlanetScale, Railway, or Local MySQL
DATABASE_URL="mysql://user:password@host:3306/mediverify"

# Authentication Security
JWT_SECRET="secure_random_string_here"
NEXTAUTH_SECRET="another_secure_random_string"

# Application Config
NEXT_PUBLIC_API_URL="http://localhost:3000"
NODE_ENV="development"

# SMTP (required for OTP email delivery)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="MediVerify <your-email@gmail.com>"

# Blockchain Gateway (Future Integration)
BLOCKCHAIN_RPC_URL="https://eth-mainnet.g.alchemy.com/v2/your-api-key"
PRIVATE_KEY="your-wallet-private-key"
